# Environment
ENVIRONMENT=production
DEBUG=False

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-50-characters

# Hosts and Domains
ALLOWED_HOSTS=.onrender.com,litsey-test.vercel.app,localhost,127.0.0.1

# CORS Settings (Frontend Domains)
CORS_ALLOWED_ORIGINS=https://litsey-test.vercel.app,http://localhost:3000,http://localhost:5173

# CSRF Settings
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,https://litsey-test.vercel.app,http://localhost:3000,http://localhost:5173

# Database (Render automatically sets DATABASE_URL for PostgreSQL)
DATABASE_URL=

# Optional: For development with local database
# DATABASE_URL=postgresql://user:password@localhost:5432/jahoongir_db

